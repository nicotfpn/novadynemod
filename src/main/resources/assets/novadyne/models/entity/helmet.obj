# NovaDyne Mark I Helmet - Low Poly Test Model
# Coordinates relative to head pivot (0, 24, 0)
# Each face is a quad (4 vertices), loader will triangulate
# All normals point outward, CCW winding
# Uses RenderType.entityCutoutNoCull (no backface culling)

# Vertices (8 corners of a box)
v -4.5 -0.5 -4.5
v  4.5 -0.5 -4.5
v  4.5  8.5 -4.5
v -4.5  8.5 -4.5
v -4.5 -0.5  4.5
v  4.5 -0.5  4.5
v  4.5  8.5  4.5
v -4.5  8.5  4.5

# UVs (OBJ convention - V=0 at bottom, loader flips to Minecraft convention)
vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Normals (one per face direction, pointing outward)
vn 0.0 0.0 -1.0
vn 0.0 0.0  1.0
vn 1.0 0.0  0.0
vn -1.0 0.0  0.0
vn 0.0 1.0  0.0
vn 0.0 -1.0  0.0

# Faces (quads, CCW winding from outside)
f 1/1/1 4/2/1 3/3/1 2/4/1
f 5/1/2 6/2/2 7/3/2 8/4/2
f 2/1/3 3/2/3 7/3/3 6/4/3
f 1/1/4 5/2/4 8/3/4 4/4/4
f 4/1/5 8/2/5 7/3/5 3/4/5
f 1/1/6 2/2/6 6/3/6 5/4/6
